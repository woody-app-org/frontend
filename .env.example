# Copie para .env.development.local se quiser overrides só na tua máquina (*.local está no .gitignore).

# Modo de lançamento (build-time — exige rebuild ao alterar):
# VITE_PUBLIC_LAUNCH_MODE=app            — aplicação normal (padrão se omitido)
# VITE_PUBLIC_LAUNCH_MODE=waitlist_form  — formulário de pré-inscrição
# VITE_PUBLIC_LAUNCH_MODE=coming_soon      — tela estática de lançamento em breve

# Beta fechado (UX): com true, rotas públicas de entrada/onboarding exigem convite validado em sessão.
# Valores aceites: "true" ou omitido/false para comportamento normal.
# VITE_BETA_CLOSED=true

# Desenvolvimento local (API ASP.NET em HTTP — launchSettings porta 5000)
# VITE_API_BASE_URL=http://localhost:5000

# Produção / preview: obrigatório no build (ex. variável no Railway, Vercel, etc.)
# VITE_API_BASE_URL=https://sua-api.example.com
